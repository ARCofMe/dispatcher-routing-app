# Example environment variables for the frontend application
# Replace the placeholder values with your actual configurations

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
# Google Map ID
VITE_GOOGLE_MAP_ID=YOUR_GOOGLE_MAP_ID
# Disable client-side geocoding (rely on backend for coordinates)
VITE_DISABLE_CLIENT_GEOCODE=true

# BlueFolder account subdomain
VITE_BLUEFOLDER_ACCOUNT_NAME=YOUR_BLUEFOLDER_SUBDOMAIN

# Set to 'true' to disable Google Maps Directions API calls
VITE_DISABLE_DIRECTIONS=false

# Set to 'true' to use Leaflet instead of Google Maps for map rendering
VITE_USE_LEAFLET=false

# Set to 'true' to disable Google Maps Directions API calls
VITE_DISABLE_DIRECTIONS=false 

# Example environment variables for the backend application
# Replace the placeholder values with your actual configurations

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google Map ID
VITE_GOOGLE_MAP_ID=

# BlueFolder account subdomain
VITE_BLUEFOLDER_ACCOUNT_NAME=
BLUEFOLDER_API_KEY=
BLUEFOLDER_ACCOUNT_NAME=
# Optional: override BlueFolder base URL (e.g., https://<IP>/api/2.0) and host header / SSL verify
BLUEFOLDER_BASE_URL=
BLUEFOLDER_HOST_HEADER=
BLUEFOLDER_VERIFY_SSL=false
BLUEFOLDER_TIMEOUT_SECONDS=30
BLUEFOLDER_RETRY_TOTAL=3
BLUEFOLDER_RETRY_BACKOFF=1
# Optional: offline fallback file path (JSON list of assignments) used when BF is unreachable
BLUEFOLDER_OFFLINE_FILE=

# Set to 'true' to use Leaflet instead of Google Maps for map rendering
VITE_USE_LEAFLET=true
# Set to 'true' to disable Google Maps Directions API calls
VITE_DISABLE_DIRECTIONS=true   # so the frontend never calls Google Directions

# Set to 'true' to disable Google geocoding (use Nominatim/OSM instead)
DISABLE_GMAPS_GEOCODER=true
# Optional: point geocoding to a self-hosted Nominatim endpoint (e.g., http://nominatim.internal)
NOMINATIM_URL=
# Set to 'true' to disable Google Maps Directions API calls
DISABLE_GMAPS_DIRECTIONS=false
# Optional: Geoapify API key (used for geocoding when provided)
GEOAPIFY_API_KEY=
# When a Geoapify key is present, a small routing matrix is used for road-aware optimization.
# Set to 'true' to honor service windows when optimizing (buckets by window_start)
OPTIMIZE_RESPECT_WINDOWS=true
